<%= content_tag tag, class: wrapper_classes do %>
  <% if title %>
    <div class="font-semibold"><%= title %></div>
  <% end %>
  <% if meta %>
    <div class="mt-1 text-xs text-slate-400"><%= meta %></div>
  <% end %>
  <% if body %>
    <div class="mt-2 text-slate-300"><%= body %></div>
  <% end %>
  <% if footer %>
    <div class="mt-3"><%= footer %></div>
  <% end %>
<% end %>
