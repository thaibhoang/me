<%= content_tag tag, class: wrapper_classes do %>
  <% if title %>
    <div class="font-semibold tracking-tight text-slate-100"><%= title %></div>
  <% end %>
  <% if meta %>
    <div class="mt-1 text-xs uppercase tracking-wide text-slate-500"><%= meta %></div>
  <% end %>
  <% if body %>
    <div class="mt-2 text-sm leading-relaxed text-slate-300"><%= body %></div>
  <% end %>
  <% if footer %>
    <div class="mt-4"><%= footer %></div>
  <% end %>
<% end %>
