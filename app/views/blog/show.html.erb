<article class="max-w-3xl space-y-6">
  <header>
    <h1 class="text-4xl font-bold"><%= @post.title %></h1>
    <p class="mt-2 text-slate-400"><%= @post.published_at&.to_date || @post.created_at.to_date %></p>
    <div class="mt-3 flex flex-wrap gap-2">
      <% @post.tags.each do |tag| %>
        <%= render Ui::ButtonComponent.new(label: "##{tag.slug}", href: blog_index_path(tag: tag.slug), variant: :chip_active, classes: "px-2 text-xs") %>
      <% end %>
    </div>
  </header>

  <p class="text-lg text-slate-200"><%= @post.excerpt %></p>
  <div class="prose prose-invert max-w-none">
    <%= simple_format(@post.content) %>
  </div>
</article>
