<section>
  <h1 class="text-3xl font-bold">Blog</h1>
  <p class="mt-2 text-slate-300">Filter theo category va tech badge.</p>
</section>

<section class="mt-6 flex flex-wrap gap-2">
  <% @categories.each do |category| %>
    <%= link_to category.name, blog_index_path(category: category.slug), class: "rounded border border-slate-700 px-3 py-1 text-sm" %>
  <% end %>
  <% @tags.each do |tag| %>
    <%= link_to "##{tag.slug}", blog_index_path(tag: tag.slug), class: "rounded border border-emerald-700 px-3 py-1 text-sm text-emerald-300" %>
  <% end %>
</section>

<section class="mt-8 space-y-4">
  <% @posts.each do |post| %>
    <article class="rounded border border-slate-800 p-4">
      <h2 class="text-xl font-semibold"><%= link_to post.title, blog_post_path(post.slug), class: "hover:text-emerald-300" %></h2>
      <p class="text-xs text-slate-400 mt-1"><%= post.published_at&.to_date || post.created_at.to_date %></p>
      <p class="mt-2 text-slate-300"><%= post.excerpt %></p>
    </article>
  <% end %>
</section>
