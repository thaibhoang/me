<%= render Ui::SectionTitleComponent.new(title: "Blog", subtitle: "Filter theo category va tech badge.", level: 1, classes: "text-3xl font-bold") %>

<section class="mt-6 flex flex-wrap gap-2">
  <% @categories.each do |category| %>
    <%= render Ui::ButtonComponent.new(label: category.name, href: blog_index_path(category: category.slug), variant: :chip) %>
  <% end %>
  <% @tags.each do |tag| %>
    <%= render Ui::ButtonComponent.new(label: "##{tag.slug}", href: blog_index_path(tag: tag.slug), variant: :chip_active) %>
  <% end %>
</section>

<%= render Ui::SectionBlockComponent.new(classes: "mt-8 space-y-4") do %>
  <% @posts.each do |post| %>
    <%= render Ui::CardComponent.new do |card| %>
      <% card.with_title do %>
        <%= link_to post.title, blog_post_path(post.slug), class: "text-xl hover:text-emerald-300" %>
      <% end %>
      <% card.with_meta { post.published_at&.to_date || post.created_at.to_date } %>
      <% card.with_body { post.excerpt } %>
    <% end %>
  <% end %>
<% end %>
