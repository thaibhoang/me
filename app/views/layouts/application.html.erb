<!DOCTYPE html>
<html>
  <head>
    <title><%= current_page_meta[:title] %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="<%= current_page_meta[:description] %>">
    <link rel="canonical" href="<%= current_page_meta[:canonical] %>">
    <meta property="og:title" content="<%= current_page_meta[:title] %>">
    <meta property="og:description" content="<%= current_page_meta[:description] %>">
    <meta property="og:type" content="<%= current_page_meta[:type] %>">
    <meta property="og:url" content="<%= current_page_meta[:url] %>">
    <meta property="og:image" content="<%= current_page_meta[:image] %>">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= current_page_meta[:title] %>">
    <meta name="twitter:description" content="<%= current_page_meta[:description] %>">
    <meta name="twitter:image" content="<%= current_page_meta[:image] %>">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Me">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-slate-950 text-slate-100">
    <header class="fixed top-0 z-50 w-full border-b border-slate-800/60 bg-slate-950/90 backdrop-blur">
      <nav class="mx-auto flex h-20 w-full max-w-7xl flex-wrap items-center justify-between gap-3 px-4 sm:px-6 lg:px-8">
        <%= link_to "THE_ARCHITECT", root_path, class: "text-xl font-semibold tracking-tight text-emerald-400 sm:text-2xl" %>
        <div class="order-3 flex w-full items-center justify-between gap-2 text-xs uppercase tracking-wide sm:order-2 sm:w-auto sm:gap-6 sm:text-sm sm:normal-case sm:tracking-normal">
          <%= link_to "Blog", blog_index_path, class: "hover:text-emerald-300 #{current_page?(blog_index_path) ? 'text-emerald-300' : 'text-slate-300'}" %>
          <%= link_to "Portfolio", projects_index_path, class: "hover:text-emerald-300 #{current_page?(projects_index_path) ? 'text-emerald-300' : 'text-slate-300'}" %>
          <%= link_to "About", about_path, class: "hover:text-emerald-300 #{current_page?(about_path) ? 'text-emerald-300' : 'text-slate-300'}" %>
          <%= link_to "Contact", contact_path, class: "hover:text-emerald-300 #{current_page?(contact_path) ? 'text-emerald-300' : 'text-slate-300'}" %>
        </div>
        <%= link_to "Hire Me", contact_path, class: "order-2 rounded-full bg-emerald-400 px-4 py-2 text-xs font-semibold uppercase tracking-widest text-slate-950 transition hover:bg-emerald-300 sm:order-3 sm:px-6 sm:py-2.5" %>
      </nav>
    </header>
    <main class="mx-auto w-full max-w-7xl px-4 pb-16 pt-28 sm:px-6 sm:pt-32 lg:px-8 lg:pt-36">
      <% flash.each do |name, message| %>
        <p class="mb-4 rounded bg-emerald-900/40 border border-emerald-700 px-4 py-2"><%= message %></p>
      <% end %>
      <%= yield %>
    </main>
  </body>
</html>
