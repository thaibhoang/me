<!DOCTYPE html>
<html>
  <head>
    <title><%= current_page_meta[:title] %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="<%= current_page_meta[:description] %>">
    <link rel="canonical" href="<%= current_page_meta[:canonical] %>">
    <meta property="og:title" content="<%= current_page_meta[:title] %>">
    <meta property="og:description" content="<%= current_page_meta[:description] %>">
    <meta property="og:type" content="<%= current_page_meta[:type] %>">
    <meta property="og:url" content="<%= current_page_meta[:url] %>">
    <meta property="og:image" content="<%= current_page_meta[:image] %>">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= current_page_meta[:title] %>">
    <meta name="twitter:description" content="<%= current_page_meta[:description] %>">
    <meta name="twitter:image" content="<%= current_page_meta[:image] %>">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Me">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-slate-950 text-slate-100">
    <header class="border-b border-slate-800">
      <nav class="container mx-auto px-5 py-4 flex items-center justify-between">
        <%= link_to "THE_ARCHITECT", root_path, class: "font-semibold tracking-wide text-emerald-400" %>
        <div class="flex items-center gap-4 text-sm">
          <%= link_to "Blog", blog_index_path, class: "hover:text-emerald-300" %>
          <%= link_to "Portfolio", projects_index_path, class: "hover:text-emerald-300" %>
          <%= link_to "About", about_path, class: "hover:text-emerald-300" %>
          <%= link_to "Contact", contact_path, class: "hover:text-emerald-300" %>
        </div>
      </nav>
    </header>
    <main class="container mx-auto px-5 py-10">
      <% flash.each do |name, message| %>
        <p class="mb-4 rounded bg-emerald-900/40 border border-emerald-700 px-4 py-2"><%= message %></p>
      <% end %>
      <%= yield %>
    </main>
  </body>
</html>
