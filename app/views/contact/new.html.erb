<section class="grid gap-8 lg:grid-cols-12 lg:gap-12">
  <%= render Ui::SectionBlockComponent.new(classes: "lg:col-span-7") do %>
    <%= render Ui::SectionTitleComponent.new(title: "Contact", subtitle: "Gui thong tin de trao doi co hoi hop tac.", level: 1, classes: "text-4xl font-bold sm:text-5xl") %>

    <%= form_with model: @contact_message, url: contact_submit_path, class: "mt-6 space-y-4", data: { analytics_event: "contact_submit", analytics_source: "contact_form" } do |f| %>
      <div class="grid gap-4 md:grid-cols-2">
        <div>
          <%= f.label :name, class: "text-sm text-slate-300" %>
          <%= f.text_field :name, class: "mt-1 w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-2" %>
        </div>
        <div>
          <%= f.label :email, class: "text-sm text-slate-300" %>
          <%= f.email_field :email, class: "mt-1 w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-2" %>
        </div>
      </div>
      <div>
        <%= f.label :subject, class: "text-sm text-slate-300" %>
        <%= f.text_field :subject, class: "mt-1 w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-2" %>
      </div>
      <div>
        <%= f.label :message, class: "text-sm text-slate-300" %>
        <%= f.text_area :message, rows: 5, class: "mt-1 w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-2" %>
      </div>
      <%= f.submit "Send message", class: Ui::ButtonComponent::STYLES[:primary] %>
    <% end %>
  <% end %>

  <aside class="space-y-4 lg:col-span-5">
    <%= render Ui::CardComponent.new do |card| %>
      <% card.with_title { "Direct Handshake" } %>
      <% card.with_body { "Email: hello@thearchitect.dev" } %>
    <% end %>
    <%= render Ui::CardComponent.new do |card| %>
      <% card.with_title { "Social Infrastructure" } %>
      <% card.with_body { "GitHub / LinkedIn / Twitter" } %>
    <% end %>
  </aside>
</section>
