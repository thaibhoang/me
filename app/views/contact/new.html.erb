<section class="max-w-2xl">
  <h1 class="text-3xl font-bold">Contact</h1>
  <p class="mt-2 text-slate-300">Gui thong tin de trao doi co hoi hop tac.</p>

  <%= form_with model: @contact_message, url: contact_submit_path, class: "mt-6 space-y-4" do |f| %>
    <div>
      <%= f.label :name %>
      <%= f.text_field :name, class: "mt-1 w-full rounded bg-slate-900 border-slate-700" %>
    </div>
    <div>
      <%= f.label :email %>
      <%= f.email_field :email, class: "mt-1 w-full rounded bg-slate-900 border-slate-700" %>
    </div>
    <div>
      <%= f.label :subject %>
      <%= f.text_field :subject, class: "mt-1 w-full rounded bg-slate-900 border-slate-700" %>
    </div>
    <div>
      <%= f.label :message %>
      <%= f.text_area :message, rows: 5, class: "mt-1 w-full rounded bg-slate-900 border-slate-700" %>
    </div>
    <%= f.submit "Send message", class: "rounded bg-emerald-500 px-4 py-2 text-black font-semibold cursor-pointer" %>
  <% end %>
</section>
