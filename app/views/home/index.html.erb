<%= render Ui::SectionBlockComponent.new(classes: "space-y-6") do %>
  <p class="text-xs uppercase tracking-widest text-emerald-400">System Ready</p>
  <h1 class="text-4xl font-bold">Architecting Scalable Digital Infrastructure.</h1>
  <p class="max-w-2xl text-slate-300">
    Toi xay dung nen tang backend hieu nang cao va chia se cac bai hoc thuc chien qua blog.
  </p>
  <div class="flex gap-3">
    <%= render Ui::ButtonComponent.new(label: "View Projects", href: projects_index_path, variant: :primary) %>
    <%= render Ui::ButtonComponent.new(label: "Read Blog", href: blog_index_path, variant: :secondary) %>
  </div>
<% end %>

<%= render Ui::SectionBlockComponent.new(classes: "mt-14") do %>
  <%= render Ui::SectionTitleComponent.new(title: "Featured Projects") %>
  <div class="grid gap-4 md:grid-cols-3">
    <% @featured_projects.each do |project| %>
      <%= render Ui::CardComponent.new do |card| %>
        <% card.with_title do %>
          <%= link_to project.title, project_path(project.slug), class: "hover:text-emerald-300" %>
        <% end %>
        <% card.with_body { project.summary } %>
      <% end %>
    <% end %>
  </div>
<% end %>

<%= render Ui::SectionBlockComponent.new(classes: "mt-14") do %>
  <%= render Ui::SectionTitleComponent.new(title: "Latest Posts") %>
  <div class="space-y-3">
    <% @latest_posts.each do |post| %>
      <%= render Ui::CardComponent.new do |card| %>
        <% card.with_title do %>
          <%= link_to post.title, blog_post_path(post.slug), class: "hover:text-emerald-300" %>
        <% end %>
        <% card.with_body { post.excerpt } %>
      <% end %>
    <% end %>
  </div>
<% end %>
