<article class="space-y-10">
  <header class="space-y-4">
    <h1 class="text-4xl font-bold leading-tight tracking-tight sm:text-5xl lg:text-6xl"><%= @project.title %></h1>
    <p class="max-w-4xl text-sm leading-relaxed text-slate-300 sm:text-base lg:text-lg"><%= @project.summary %></p>
  </header>

  <section class="grid gap-8 lg:grid-cols-12 lg:items-start">
    <div class="space-y-6 lg:col-span-8">
      <%= render Ui::SectionTitleComponent.new(title: "Technical Visuals") %>
      <section class="grid gap-4 md:grid-cols-2">
        <% @project.project_visuals.order(:position).each do |visual| %>
          <%= render Ui::CardComponent.new(tag: :figure, classes: "p-3") do |card| %>
            <% card.with_body do %>
              <img src="<%= visual.image_url %>" alt="<%= visual.title.presence || @project.title %>" class="w-full rounded">
            <% end %>
            <% if visual.caption.present? %>
              <% card.with_footer do %>
                <figcaption class="text-sm text-slate-400"><%= visual.caption %></figcaption>
              <% end %>
            <% end %>
          <% end %>
        <% end %>
      </section>
    </div>
    <aside class="lg:col-span-4 lg:sticky lg:top-32">
      <%= render Ui::CardComponent.new do |card| %>
        <% card.with_title { "Links" } %>
        <% card.with_body do %>
          <div class="flex flex-wrap gap-2">
            <% @project.project_links.order(:position).each do |link| %>
              <%= render Ui::ButtonComponent.new(label: link.label, href: link.url, variant: :chip_active, html_options: { data: { analytics_event: "project_outbound_click", analytics_source: "project_links", analytics_label: link.label } }) %>
            <% end %>
          </div>
        <% end %>
      <% end %>
    </aside>
  </section>
</article>
