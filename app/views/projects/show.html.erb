<article class="space-y-8">
  <header>
    <h1 class="text-4xl font-bold"><%= @project.title %></h1>
    <p class="mt-3 max-w-3xl text-slate-300"><%= @project.summary %></p>
  </header>

  <section>
    <%= render Ui::SectionTitleComponent.new(title: "Links") %>
    <div class="flex flex-wrap gap-2">
      <% @project.project_links.order(:position).each do |link| %>
        <%= render Ui::ButtonComponent.new(label: link.label, href: link.url, variant: :chip_active) %>
      <% end %>
    </div>
  </section>

  <section class="grid gap-4 md:grid-cols-2">
    <% @project.project_visuals.order(:position).each do |visual| %>
      <%= render Ui::CardComponent.new(tag: :figure, classes: "p-3") do |card| %>
        <% card.with_body do %>
          <img src="<%= visual.image_url %>" alt="<%= visual.title.presence || @project.title %>" class="w-full rounded">
        <% end %>
        <% if visual.caption.present? %>
          <% card.with_footer do %>
            <figcaption class="text-sm text-slate-400"><%= visual.caption %></figcaption>
          <% end %>
        <% end %>
      <% end %>
    <% end %>
  </section>
</article>
