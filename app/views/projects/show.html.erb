<article class="space-y-8">
  <header>
    <h1 class="text-4xl font-bold"><%= @project.title %></h1>
    <p class="mt-3 max-w-3xl text-slate-300"><%= @project.summary %></p>
  </header>

  <section>
    <h2 class="text-2xl font-semibold mb-3">Links</h2>
    <div class="flex flex-wrap gap-2">
      <% @project.project_links.order(:position).each do |link| %>
        <a class="rounded border border-emerald-700 px-3 py-1 text-sm text-emerald-300" href="<%= link.url %>"><%= link.label %></a>
      <% end %>
    </div>
  </section>

  <section class="grid gap-4 md:grid-cols-2">
    <% @project.project_visuals.order(:position).each do |visual| %>
      <figure class="rounded border border-slate-800 p-3">
        <img src="<%= visual.image_url %>" alt="<%= visual.title.presence || @project.title %>" class="w-full rounded">
        <% if visual.caption.present? %><figcaption class="mt-2 text-sm text-slate-400"><%= visual.caption %></figcaption><% end %>
      </figure>
    <% end %>
  </section>
</article>
