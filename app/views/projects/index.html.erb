<%= render Ui::SectionTitleComponent.new(title: "Portfolio", subtitle: "Case study va ket qua du an.", level: 1, classes: "text-3xl font-bold") %>

<section class="mt-8 grid gap-4 md:grid-cols-2">
  <% @projects.each do |project| %>
    <%= render Ui::CardComponent.new(classes: "p-5") do |card| %>
      <% card.with_title do %>
        <%= link_to project.title, project_path(project.slug), class: "text-xl hover:text-emerald-300" %>
      <% end %>
      <% card.with_body { project.summary } %>
    <% end %>
  <% end %>
</section>
