<section>
  <h1 class="text-3xl font-bold">Portfolio</h1>
  <p class="mt-2 text-slate-300">Case study va ket qua du an.</p>
</section>

<section class="mt-8 grid gap-4 md:grid-cols-2">
  <% @projects.each do |project| %>
    <article class="rounded border border-slate-800 p-5">
      <h2 class="text-xl font-semibold"><%= link_to project.title, project_path(project.slug), class: "hover:text-emerald-300" %></h2>
      <p class="mt-2 text-slate-300"><%= project.summary %></p>
    </article>
  <% end %>
</section>
